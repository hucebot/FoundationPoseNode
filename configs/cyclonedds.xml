<CycloneDDS>
  <Domain>
    <General>
      <!-- Define which network interface to use -->
      <Interfaces>
        <NetworkInterface name="enp0s31f6" priority="1" />
      </Interfaces>
      <MaxMessageSize>1400B</MaxMessageSize>

      <!-- Explicitly allow/control multicast -->
      <AllowMulticast>true</AllowMulticast>

      <!-- Optional: Change the multicast group if you have collisions -->
    </General>
    <Discovery>
      <!-- Force discovery to use multicast -->
      <ParticipantIndex>auto</ParticipantIndex>
      <MaxAutoParticipantIndex>10</MaxAutoParticipantIndex>
    </Discovery>
  </Domain>
</CycloneDDS>